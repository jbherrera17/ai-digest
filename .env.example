# AIDigest Environment Variables
# Copy this to .env and fill in your values

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Enable database mode (set to 'true' to use Supabase instead of hardcoded feeds)
USE_DATABASE=false

# Admin API Token (optional - leave blank for dev mode with no auth)
# In production, set this to a secure random string
ADMIN_API_TOKEN=

# Anthropic API Key (required for Claude-powered article summaries)
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ============================================
# Higgins 2.0 (REQ-002)
# ============================================

# Vercel AI Gateway — auto-injected on Vercel-linked projects when the
# AI Gateway integration is enabled. Set locally for `vercel dev`.
AI_GATEWAY_API_KEY=

# Shared bearer token for /api/chat. Single-user (JB-only) gate for v1.
# Generate with: openssl rand -hex 32
HIGGINS_API_TOKEN=

# Vercel Blob — required for Phase 4 (DocX/PPTX server-rendered artifacts).
# Provisioned via Vercel Storage → Blob.
BLOB_READ_WRITE_TOKEN=
